# Business Management System Environment Variables

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
# For SQLite (development)
DATABASE_URL=sqlite:///business_management.db

# For MySQL on Bluehost (production)
# DATABASE_URL=mysql+pymysql://username:password@hostname/dbname

# Application Settings
GST_RATE=0.10

# Server Configuration
SERVER_NAME=localhost:5000

# Public App URL
APP_BASE_URL=http://127.0.0.1:5001

# Email Configuration
MAIL_ENABLED=true
MAIL_HOST=mail.westernitsolutions.com.au
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USERNAME=accounts@westernitsolutions.com.au
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=accounts@westernitsolutions.com.au
